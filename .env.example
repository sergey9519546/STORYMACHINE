# GEMINI_API_KEY: Optional — the server boots WITHOUT this into analysis-only
# mode (doctor, diagnose, coverage, what-if, room, interview receipts all work
# keyless). Required only to enable AI-backed features when AI_PROVIDER=gemini
# (the default). /api/ai-config's llmReady is true if EITHER this OR the
# multi-provider AI_API_KEY below is set — checking only one is a known trap.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ── Multi-provider AI config (all optional — defaults to Gemini) ──────────────

# Text LLM provider
# AI_PROVIDER=gemini                        # or openai-compat
# AI_BASE_URL=https://openrouter.ai/api/v1  # required for openai-compat
# AI_API_KEY=sk-...                         # required for openai-compat
# AI_MODEL=google/gemini-2.5-pro            # model override (pro tier)
# AI_FAST_MODEL=google/gemini-2.5-flash     # model override (fast tier)

# Image provider (defaults to AI_PROVIDER; "none" disables image generation)
# AI_IMG_PROVIDER=gemini                    # or openai-compat or none
# AI_IMG_BASE_URL=https://api.openai.com/v1
# AI_IMG_API_KEY=sk-...
# AI_IMG_MODEL=dall-e-3

# TTS provider (defaults to AI_PROVIDER; "none" disables TTS)
# AI_TTS_PROVIDER=gemini                    # or openai-compat or none
# AI_TTS_BASE_URL=https://api.openai.com/v1
# AI_TTS_API_KEY=sk-...
# AI_TTS_MODEL=tts-1
# AI_TTS_VOICE=alloy

# Embedding provider (defaults to gemini — used for semantic belief detection)
# AI_EMBEDDING_PROVIDER=gemini              # or openai-compat or none
# AI_EMBEDDING_BASE_URL=https://api.openai.com/v1
# AI_EMBEDDING_API_KEY=sk-...
# AI_EMBEDDING_MODEL=text-embedding-3-small

# Gemini-specific model overrides (used when AI_PROVIDER=gemini)
# GEMINI_MODEL=gemini-2.5-pro
# GEMINI_FAST_MODEL=gemini-2.5-flash
# GEMINI_IMG_MODEL=gemini-2.5-flash-preview-image-generation
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# GEMINI_TEMPERATURE=1.0

# Per-task model tier + cost overrides (advanced, all optional)
# AI_TASK_TIER_CANDIDATE=pro             # override one task's tier: fast|pro
#                                        # (task names: OUTLINE, CANDIDATE, REVISION,
#                                        # WORLDBUILD, DIALOGUE, ANALYSIS, GHOST_TEXT, ...)
# AI_COST_INPUT_PER_M=0.075              # USD per 1M prompt tokens, for cost estimation
# AI_COST_OUTPUT_PER_M=0.30              # USD per 1M output tokens, for cost estimation

# ── Collaboration (all optional) ─────────────────────────────────────────────
# COLLAB_SECRET=some-long-random-string  # HMAC secret signing collab room tokens.
#                                        # Set this in any deployment with more than
#                                        # one server process (or restarts) — unset
#                                        # falls back to a per-process random secret,
#                                        # so tokens stop validating across restarts.
#                                        # REQUIRED in production: POST /api/collab/token
#                                        # returns 503 if NODE_ENV=production and this is unset.
# COLLAB_MAX_ROOMS=200                   # Max concurrent Yjs collab rooms (default: 200)

# ── Security (all optional) ──────────────────────────────────────────────────
# METRICS_TOKEN=some-long-random-string  # When set, GET /metrics requires
#                                        # `Authorization: Bearer <token>` (404 otherwise).
#                                        # UNSET (default): /metrics is loopback-only
#                                        # (127.0.0.1/::1) — it exposes token usage and
#                                        # cost estimates, so never expose it to the internet
#                                        # without setting this. /health stays open.
# ADMIN_TOKEN=some-long-random-string    # When set, POST /api/ai-config and POST
#                                        # /api/ai-config/test require `Authorization:
#                                        # Bearer <token>` (401 otherwise), from EVERY
#                                        # caller including loopback. UNSET (default):
#                                        # these routes are loopback-only (127.0.0.1/::1)
#                                        # — without this, any remote caller could rewrite
#                                        # the server's AI provider config. GET /api/ai-config
#                                        # stays open (booleans only, no key material).
# AI_ALLOW_PRIVATE_NETWORK_TARGETS=true  # Opt-in to allow AI provider baseURLs pointing at
#                                        # loopback/private-network hosts (self-hosted Ollama,
#                                        # LM Studio). Default (unset): in production, provider
#                                        # URLs resolving to private/loopback/link-local ranges
#                                        # are rejected as SSRF. Leave unset unless you run a
#                                        # local model server.

# ── Server config (all optional) ─────────────────────────────────────────────
# PORT=3000                              # HTTP port (default: 3000)
# NODE_ENV=production                    # Set to production to serve pre-built frontend from ./dist
# TRUST_PROXY=1                          # Trust the first hop's X-Forwarded-For (set when a
#                                        # reverse proxy/load balancer terminates in front of this
#                                        # process — otherwise rate limiting and req.ip collapse
#                                        # onto the proxy's own IP). Also accepts a hop count, an
#                                        # IP/CIDR, or 'loopback' (Express's `trust proxy` values).
#                                        # Unset (default): no trust-proxy config applied.

# ── Session persistence (all optional) ───────────────────────────────────────
# MAX_SESSIONS=100                       # Max concurrent in-memory sessions (default: 100)
# SESSION_DB_DIR=data/sessions           # Directory for per-session SQLite files (default:
#                                        # ./data/sessions). Set to :memory: to disable disk
#                                        # persistence entirely (ephemeral sessions only).
# SESSION_IDLE_TTL_MINUTES=1440          # Minutes of inactivity before a session is evicted from
#                                        # memory (default: 1440 = 24h). Lower on memory-constrained
#                                        # deployments; PERSIST mode re-hydrates from disk regardless.
# SESSION_FILE_TTL_HOURS=168             # Hours before orphaned session DB files are deleted (default: 168 = 7 days)
