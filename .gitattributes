# Normalize line endings — repo is CRLF-dirty from OneDrive sync (has corrupted
# lockfiles + source copies this cycle). After committing this file, run once:
#   git add --renormalize . && git commit -m "normalize EOL to LF"
* text=auto eol=lf
*.png binary
*.pdf binary
*.zip binary
*.gz binary
*.json text eol=lf
