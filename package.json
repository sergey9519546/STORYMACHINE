{
  "name": "storymachine",
  "private": true,
  "version": "1.0.0",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=22.6"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "start": "tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "node --experimental-strip-types --test 'evals/scoring/**/*.test.ts' 'server/nvm/analyze/**/*.test.ts' 'server/nvm/proof/**/*.test.ts' 'tests/collab/**/*.test.ts' 'tests/core/**/*.test.ts' 'tests/e2e/**/*.test.ts' 'tests/nvm/**/*.test.ts' 'tests/passes/**/*.test.ts' 'tests/routes/**/*.test.ts'",
    "test:metamorphic": "node --experimental-strip-types evals/scoring/runner/run-metamorphic.ts",
    "rulebook": "node --experimental-strip-types scripts/generate-rulebook.ts",
    "generate-p0-sample": "node --experimental-strip-types scripts/generate-p0-sample-report.ts",
    "measure-slop": "node --experimental-strip-types scripts/measure-slop-discrimination.ts",
    "honesty-audit": "node scripts/honesty-audit.mjs",
    "backup": "node --experimental-strip-types scripts/backup-sessions.ts",
    "check-docs": "node --experimental-strip-types scripts/check-docs-quality.ts --all",
    "check-docs:strict": "node --experimental-strip-types scripts/check-docs-quality.ts --all --strict",
    "setup-hooks": "cp scripts/pre-commit.sh .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit && echo '✓ Git hooks installed'",
    "validate": "npm run lint && npm run check-docs && npm test"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.21.0",
    "y-codemirror.next": "^0.3.5",
    "y-protocols": "^1.0.7",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.31",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
