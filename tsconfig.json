{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  // QUARANTINE (non-destructive): the v5.0 "narrative OS" experimental
  // subsystem merged in feat(audit)/cbf56a4 never compiled (241 tsc errors
  // pre-quarantine). None of this is wired into the running server
  // (routes/app/server.ts) except the small live closure reachable from
  // server/engine/Stage.ts, which is fixed in place, not excluded. Everything
  // below stays in the repo untouched — re-include piecemeal as each area is
  // finished. See CLAUDE.md "Standing task" for why: the wave-generated rule
  // catalog and this WIP research surface are both explicitly deprioritized
  // behind demand-first validation (ROADMAP P0-P2).
  "exclude": [
    "node_modules",
    "dist",
    "server/nvm/quantum",
    "server/nvm/research",
    "server/nvm/infinity-gate",
    "server/planning",
    "**/*.bench.ts",
    "server/nvm/kernel/adapters/type-enrichment.ts",
    "server/nvm/kernel/adapters/type-enrichment.test.ts",
    "server/nvm/kernel/adapters/index.ts",
    "server/nvm/kernel/v5-examples.ts",
    "server/nvm/kernel/adapters.ts",
    "server/nvm/kernel/__tests__",
    "server/nvm/kernel/event-store.test.ts",
    "server/nvm/kernel/index.ts",
    "server/nvm/kernel/integration.ts",
    "server/nvm/kernel/trinity-gate.ts",
    "server/nvm/kernel/trinity-gate-example.ts",
    "server/nvm/kernel/trinity-gate-demo.ts",
    "server/nvm/kernel/verifiers",
    "server/nvm/live/v5-loop.ts",
    "server/nvm/__tests__",
    "tests/apdl.test.ts",
    "tests/story-vector.test.ts",
    "server/engine/ai-provider.test.ts",
    "server/engine/ai-provider-integration.test.ts"
  ]
}
